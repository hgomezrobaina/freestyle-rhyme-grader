# Database
DATABASE_URL=postgresql://user:password@localhost:5432/freestyle_callificator
SQLALCHEMY_ECHO=False

# API Settings
DEBUG=True
API_TITLE=Freestyle Callificator API
API_VERSION=0.1.0

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=./uploads
TEMP_DIR=./temp

# Processing
MAX_FILE_SIZE=1000000000  # 1GB
